# Copy to .env (auto-loaded) before running.
SCRAPINGBEE_API_KEY=your-scrapingbee-api-key
# Optional — if unset, alerts print to stdout instead of posting to Slack
SLACK_WEBHOOK_URL=
# Optional — fire an alert when a competitor is this fraction below your price (default 0.05 = 5%)
UNDERCUT_THRESHOLD=0.05
# Optional — only compare prices in this currency (no FX conversion; default USD)
OUR_CURRENCY=USD
